# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend (transactional email, medoyid-club.com — verified in eu-west-1)
RESEND_API_KEY=re_...
# Default From for noreply@ only; admin@ / courses@ etc. come from src/lib/email/addresses.ts
EMAIL_FROM="Клуб медоедов <noreply@medoyid-club.com>"
# Gmail SMTP (manual replies): smtp.resend.com:465, user=resend, password=RESEND_API_KEY

# App (production: https://medoyid-club.com)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google Cloud Translation API (Studio: auto-fill UK/EN fields)
GOOGLE_TRANSLATE_API_KEY=

# Google Gemini (Studio: Google Ads pack copy generation)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# Telegram Content Hub
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Channel IDs (optional overrides; defaults from sur.txt)
TELEGRAM_CLUB_CHANNEL_ID=-1004491478231
TELEGRAM_AUTHOR_NATA_CHANNEL_ID=-1002197650405
TELEGRAM_AUTHOR_TETIANA_CHANNEL_ID=-1002194774103
# Author slugs on site (must exist in author_pages)
CONTENT_HUB_NATA_SLUG=nata-ustymenko
CONTENT_HUB_TETIANA_SLUG=tetiana-gukalo
# Optional Facebook URLs for footer links
CONTENT_HUB_NATA_FACEBOOK_URL=
CONTENT_HUB_TETIANA_FACEBOOK_URL=

# YouTube OAuth (copy token.json + client_secret to secrets/youtube/)
# Or set env vars (recommended on Vercel):
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
YOUTUBE_TOKEN_FILE=secrets/youtube/token.json

# Cron: sync author videotekas from @honey_erbe (npm run sync:youtube)
CRON_SECRET=
